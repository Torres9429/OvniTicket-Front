# URL base de la API del backend (sin slash al final)
# Producción: https://ovniticketsystem.onrender.com/api
# Desarrollo local: http://127.0.0.1:8000/api
VITE_API_URL=https://ovniticketsystem.onrender.com/api

# Claves de cifrado AES-GCM y HMAC para encriptar payloads sensibles
# Deben coincidir con las configuradas en el backend
VITE_AES_SECRET_KEY=
VITE_HMAC_SECRET_KEY=
